# ========================
# RAGNAROK — Environment Variables
# ========================
# Copy this file to .env.local and fill in the values.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=              # Supabase project URL (https://xxx.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=         # Supabase anon/public key
SUPABASE_SERVICE_ROLE_KEY=             # Supabase service role key (server-side only)

# --- Groq (LLM Battles) ---
GROQ_API_KEY=                          # Groq API key for battle judge calls

# --- Solana ---
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta  # Solana network (mainnet-beta | devnet)
NEXT_PUBLIC_SOLANA_RPC_URL=            # Public Solana RPC endpoint (browser-safe, CORS-friendly)
HELIUS_RPC_URL=                        # Helius RPC endpoint (server-side only, optional)
NEXT_PUBLIC_TREASURY_WALLET=           # Treasury wallet public address
TREASURY_PRIVATE_KEY=                  # Treasury wallet private key (server-side only, for payouts)

# --- Cron / QStash ---
CRON_SECRET=                           # MUST be set in production — authenticates cron endpoints
QSTASH_CURRENT_SIGNING_KEY=            # Upstash QStash current signing key
QSTASH_NEXT_SIGNING_KEY=              # Upstash QStash next signing key

# --- Optional ---
ANTHROPIC_API_KEY=                     # Anthropic API key (for /api/commentary route)
ADMIN_SECRET=                          # Admin secret for /api/admin/treasury-log
NEXT_PUBLIC_SITE_URL=                  # Site URL fallback (e.g. https://theragnarok.fun)
