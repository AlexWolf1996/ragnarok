# Supabase Configuration
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Solana Configuration
# Use mainnet-beta for production
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# Helius RPC (recommended for production — faster + higher limits)
# Get a free key at https://helius.dev
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Treasury Wallet
# Solana wallet address to receive bet payments (create a new wallet for this)
NEXT_PUBLIC_TREASURY_WALLET=YourTreasuryWalletPublicKeyHere

# Groq API (Required for battle execution)
# Get your API key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Anthropic API (Optional)
# For AI-powered match commentary. Falls back to templates if not set.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vercel CRON Secret
# Generate a random string for CRON authentication
CRON_SECRET=your_cron_secret_here

# Admin Secret (for treasury audit log endpoint)
ADMIN_SECRET=your_admin_secret_here

# Treasury Private Key (server-side only — for payouts)
# Base58-encoded private key of the treasury wallet
TREASURY_PRIVATE_KEY=your_treasury_private_key_here
